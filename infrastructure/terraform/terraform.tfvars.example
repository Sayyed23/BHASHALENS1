# BhashaLens Terraform Variables Example
# Copy this file to terraform.tfvars and customize for your deployment

# AWS Configuration
aws_region  = "us-east-1"
environment = "production"
project_name = "bhashalens"

# Lambda Configuration
lambda_runtime     = "python3.11"
lambda_timeout     = 30
lambda_memory_size = 512

# DynamoDB Configuration
dynamodb_billing_mode = "PAY_PER_REQUEST"

# S3 Configuration
s3_lifecycle_glacier_days = 90

# CloudWatch Configuration
cloudwatch_log_retention_days = 30

# API Gateway Configuration
api_throttle_rate_limit  = 100
api_throttle_burst_limit = 200

# Bedrock Model IDs
bedrock_model_ids = {
  claude_sonnet    = "anthropic.claude-3-sonnet-20240229-v1:0"
  titan_text       = "amazon.titan-text-premier-v1:0"
  titan_embeddings = "amazon.titan-embed-text-v2:0"
}
